page {
  --color-bg: #edf2ef;
  --color-card: #ffffff;
  --color-primary: #00a86b;
  --color-primary-dark: #0f8c5b;
  --color-primary-deep: #0a5a38;
  --color-primary-shadow: rgba(15, 140, 91, 0.25);
  --color-muted: #7a8f86;
  --color-muted-dark: #5f746b;
  --color-muted-light: #8aa296;
  --color-soft-border: rgba(1, 163, 115, 0.12);
  --color-strong-border: rgba(1, 163, 115, 0.4);
  --color-card-shadow: rgba(15, 30, 24, 0.08);
  --color-overlay: rgba(13, 31, 23, 0.35);
  --color-gradient-angle: 125deg;
  --color-disabled-bg: rgba(0, 168, 107, 0.45);
  --color-disabled-text: rgba(255, 255, 255, 0.75);
  --color-secondary-disabled-bg: rgba(1, 163, 115, 0.12);
  --color-secondary-disabled-text: rgba(13, 122, 85, 0.5);
  background-color: var(--color-bg);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  color: var(--color-primary-deep);
}

.text-muted {
  color: var(--color-muted);
}

.btn-primary {
  background: linear-gradient(var(--color-gradient-angle), var(--color-primary), var(--color-primary-dark));
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx var(--color-primary-shadow);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.99);
  box-shadow: 0 10rpx 20rpx var(--color-primary-shadow);
}

.btn-secondary {
  background-color: rgba(1, 163, 115, 0.08);
  color: var(--color-primary-dark);
  border: 2rpx solid var(--color-strong-border);
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background-color: rgba(1, 163, 115, 0.12);
}

.btn-primary[disabled],
.btn-primary[disabled='true'] {
  background: linear-gradient(var(--color-gradient-angle), var(--color-disabled-bg), rgba(0, 133, 82, 0.6));
  color: var(--color-disabled-text);
  box-shadow: none;
}

.btn-secondary[disabled],
.btn-secondary[disabled='true'] {
  background: var(--color-secondary-disabled-bg);
  color: var(--color-secondary-disabled-text);
  border-color: rgba(1, 163, 115, 0.2);
}

button[disabled] {
  opacity: 0.9;
}

.card {
  background: var(--color-card);
  border-radius: 20rpx;
  box-shadow: 0 18rpx 36rpx var(--color-card-shadow);
  border: 2rpx solid var(--color-soft-border);
}
