.shadow-page {
  padding: 40rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 100vh;
  position: relative;
}

.progress {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-label {
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #374151;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background-color: #e5e7eb;
  overflow: hidden;
}

.progress-bar__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #01c38d, #24d8c2);
}

.flow-hint {
  text-align: center;
  color: #9aa5b1;
  font-size: 26rpx;
  letter-spacing: 4rpx;
}

.rate-control {
  margin: 8rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.rate-label {
  color: #6b7280;
  font-size: 28rpx;
}

.rate-picker {
  flex: none;
}

.rate-display {
  min-width: 140rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #01c38d;
  text-align: center;
  color: #01a978;
  font-size: 26rpx;
}

.sentence {
  padding: 48rpx 40rpx;
  background: #fdfdfd;
  border: 2rpx solid #e5e7eb;
}

.sentence-text {
  font-size: 40rpx;
  line-height: 1.7;
}

.keyword-panel {
  padding: 32rpx 36rpx;
}

.keyword-title {
  font-size: 28rpx;
  color: #7b8794;
  margin-bottom: 16rpx;
}

.keyword-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-radius: 12rpx;
  background-color: #f3f4f6;
  margin-bottom: 16rpx;
}

.keyword-word {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
}

.keyword-ipa {
  display: block;
  color: #7b8794;
  margin-top: 4rpx;
}

.keyword-icon {
  font-size: 36rpx;
}

.keyword-empty {
  color: #9aa5b1;
  font-size: 26rpx;
}

.listen button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 18rpx;
  font-size: 36rpx;
}

.listen::after {
  content: '点击播放，听完后跟读';
  display: block;
  text-align: center;
  margin-top: 12rpx;
  color: #9aa5b1;
  font-size: 24rpx;
}

.secondary-actions {
  display: flex;
  gap: 24rpx;
}

.secondary-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 32rpx;
}

.loading-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.35);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  z-index: 998;
}

.loading-card {
  width: 80%;
  padding: 48rpx 40rpx;
  text-align: center;
}

.loading-title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.loading-desc {
  color: #4b5563;
  font-size: 28rpx;
  display: block;
}
