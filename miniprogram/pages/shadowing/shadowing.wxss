.shadow-page {
  padding: 40rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 100vh;
  position: relative;
}

.progress {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-label {
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-primary-deep);
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background-color: #dbe9e1;
  overflow: hidden;
}

.progress-bar__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(120deg, #00a86b, #0f8c5b);
}

.flow-hint {
  text-align: center;
  color: var(--color-muted);
  font-size: 26rpx;
  letter-spacing: 4rpx;
}

.rate-control {
  margin: 8rpx 0 16rpx;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: #f9fbfa;
}

.rate-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rate-label {
  color: var(--color-muted-dark);
  font-size: 28rpx;
}

.rate-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary-dark);
}

.rate-slider {
  width: 100%;
}

.rate-marks {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-muted-light);
}

.rate-marks text {
  flex: 1;
  text-align: center;
}

.sentence {
  padding: 48rpx 40rpx;
  background: #ffffff;
  border: 2rpx solid rgba(1, 163, 115, 0.12);
}

.sentence-text {
  font-size: 40rpx;
  line-height: 1.85;
}

.keyword-panel {
  padding: 32rpx 36rpx;
}

.keyword-title {
  font-size: 28rpx;
  color: var(--color-muted-dark);
  margin-bottom: 16rpx;
}

.keyword-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-radius: 16rpx;
  background-color: rgba(0, 168, 107, 0.08);
  margin-bottom: 16rpx;
}

.keyword-word {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
}

.keyword-ipa {
  display: block;
  color: var(--color-muted);
  margin-top: 4rpx;
}

.keyword-icon {
  font-size: 36rpx;
  color: var(--color-primary-dark);
}

.keyword-empty {
  color: var(--color-muted-light);
  font-size: 26rpx;
}

.listen button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 18rpx;
  font-size: 36rpx;
}

.listen::after {
  content: '点击播放，听完后跟读';
  display: block;
  text-align: center;
  margin-top: 12rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.secondary-actions {
  display: flex;
  gap: 24rpx;
}

.secondary-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 32rpx;
}

.loading-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: var(--color-overlay);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  z-index: 998;
}

.loading-card {
  width: 80%;
  padding: 48rpx 40rpx;
  text-align: center;
  background: #ffffff;
}

.loading-title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.loading-desc {
  color: var(--color-muted-dark);
  font-size: 28rpx;
  display: block;
}
