.shadow-page {
  padding: 40rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 100vh;
  position: relative;
}

.progress {
  text-align: center;
  font-size: 28rpx;
  color: #7b8794;
}

.sentence {
  padding: 48rpx 32rpx;
}

.sentence-text {
  font-size: 36rpx;
  line-height: 1.6;
}

.keyword-panel {
  padding: 32rpx;
}

.keyword-title {
  font-size: 28rpx;
  color: #7b8794;
  margin-bottom: 16rpx;
}

.keyword-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  background-color: #f3f4f6;
  margin-bottom: 16rpx;
}

.keyword-word {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
}

.keyword-ipa {
  display: block;
  color: #7b8794;
  margin-top: 4rpx;
}

.keyword-icon {
  font-size: 36rpx;
}

.keyword-empty {
  color: #9aa5b1;
  font-size: 26rpx;
}

.listen button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 18rpx;
  font-size: 36rpx;
}

.secondary-actions {
  display: flex;
  gap: 24rpx;
}

.secondary-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 32rpx;
}

.loading-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.35);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  z-index: 998;
}

.loading-card {
  width: 80%;
  padding: 48rpx 40rpx;
  text-align: center;
}

.loading-title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.loading-desc {
  color: #4b5563;
  font-size: 28rpx;
  display: block;
}
