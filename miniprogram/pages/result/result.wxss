.result-page {
  padding: 64rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.summary {
  padding: 48rpx;
  text-align: center;
  background: linear-gradient(145deg, var(--color-card), #f2fbf5);
}

.summary-title {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--color-primary-deep);
}

.summary-desc {
  display: block;
  font-size: 30rpx;
  color: var(--color-muted-dark);
}

.preview {
  padding: 32rpx;
  border: 2rpx solid var(--color-soft-border);
}

.preview-label {
  font-size: 28rpx;
  color: var(--color-muted-dark);
}

.preview-text {
  display: block;
  margin-top: 16rpx;
  line-height: 1.75;
  color: var(--color-primary-deep);
}

.result-actions {
  display: flex;
  gap: 24rpx;
}

.result-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 32rpx;
}
