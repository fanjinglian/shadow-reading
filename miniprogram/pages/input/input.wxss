.input-page {
  padding: 48rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.hero {
  padding: 48rpx 44rpx;
  margin-bottom: 8rpx;
  background: linear-gradient(145deg, var(--color-card) 0%, #f3fbf7 90%);
  border: 2rpx solid var(--color-soft-border);
}

.hero-title {
  font-size: 50rpx;
  font-weight: 700;
  display: block;
  color: var(--color-primary-deep);
}

.hero-badge {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 168, 107, 0.12);
  color: var(--color-primary-dark);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: var(--color-muted-dark);
  display: block;
  line-height: 1.7;
  font-size: 30rpx;
}

.hero-visual {
  margin-top: 32rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(15, 140, 91, 0.9), rgba(10, 90, 56, 0.95));
  color: #ffffff;
  box-shadow: 0 22rpx 38rpx rgba(10, 90, 56, 0.35);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hero-visual-tag {
  align-self: flex-start;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  font-size: 24rpx;
  letter-spacing: 3rpx;
}

.hero-visual-desc {
  font-size: 30rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.text-entry {
  min-height: 360rpx;
  padding: 36rpx;
  font-size: 32rpx;
  line-height: 1.8;
  border: 2rpx solid rgba(1, 163, 115, 0.15);
  background: #fdfefe;
}

.placeholder {
  color: #95a9a1;
}

.meta-row {
  margin: 8rpx 8rpx 0;
  display: flex;
  justify-content: space-between;
  color: var(--color-muted);
  font-size: 26rpx;
  letter-spacing: 1rpx;
}

.error {
  margin: 0 8rpx 16rpx;
  color: #d14343;
  font-size: 26rpx;
}

.actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.actions button {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
}
