.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  backdrop-filter: blur(6rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  z-index: 999;
}

.popup-card {
  width: 560rpx;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 64rpx;
  background: #f5f5f7;
  box-shadow: 0 24rpx 48rpx rgba(15, 23, 42, 0.18);
  position: relative;
}

.popup-close {
  cursor: pointer;
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(15, 23, 42, 0.12);
  background: #ffffff;
  color: #111827;
  font-size: 36rpx;
  line-height: 52rpx;
  text-align: center;
  box-shadow: 0 6rpx 12rpx rgba(15, 23, 42, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-word {
  font-size: 48rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
  color: #111827;
}

.popup-ipa {
  font-size: 32rpx;
  color: #4b5563;
  margin-bottom: 16rpx;
  display: block;
}

.popup-hint {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 40rpx;
  display: block;
}

.popup-play {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #01c38d, #24d8c2);
  color: #ffffff;
  font-weight: 600;
  font-size: 34rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.popup-play::after {
  border: none;
}

.popup-play-icon {
  font-size: 40rpx;
}
