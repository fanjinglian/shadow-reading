.popup-mask {
  position: fixed;
  inset: 0;
  background: var(--color-overlay, rgba(13, 31, 23, 0.5));
  backdrop-filter: blur(8rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  z-index: 999;
}

.popup-card {
  width: 560rpx;
  border-radius: 36rpx;
  padding: 56rpx 48rpx 64rpx;
  background: linear-gradient(160deg, var(--color-card) 0%, #f3fbf7 90%);
  box-shadow: 0 24rpx 48rpx rgba(13, 31, 23, 0.18);
  position: relative;
  border: 2rpx solid var(--color-soft-border);
}

.popup-close {
  cursor: pointer;
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid var(--color-soft-border);
  background: #f7fffb;
  color: var(--color-primary-deep);
  font-size: 36rpx;
  line-height: 52rpx;
  text-align: center;
  box-shadow: 0 6rpx 14rpx rgba(15, 30, 24, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-word {
  font-size: 48rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
  color: var(--color-primary-deep);
}

.popup-ipa {
  font-size: 32rpx;
  color: var(--color-muted-dark);
  margin-bottom: 16rpx;
  display: block;
}

.popup-hint {
  font-size: 26rpx;
  color: var(--color-muted);
  margin-bottom: 40rpx;
  display: block;
}

.popup-play {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 22rpx;
  background: linear-gradient(120deg, var(--color-primary), var(--color-primary-dark));
  color: #ffffff;
  font-weight: 600;
  font-size: 34rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 18rpx 28rpx var(--color-primary-shadow);
}

.popup-play::after {
  border: none;
}

.popup-play-icon {
  font-size: 40rpx;
}
